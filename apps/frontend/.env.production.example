# ── Produção — Vercel ─────────────────────────────────────────────────────────
# Cole estas variáveis no painel do Vercel: Settings → Environment Variables
# Marque como "Production" (não precisa em Development)

# URL do backend no Railway (sem barra no final)
VITE_API_URL="https://seu-backend.railway.app"

# Mesma URL para WebSocket
VITE_WS_URL="https://seu-backend.railway.app"
