# ── Produção — Railway ────────────────────────────────────────────────────────
# Cole estas variáveis no painel do Railway: Settings → Variables

# Fornecida automaticamente pelo plugin PostgreSQL do Railway
# OU cole a connection string do Neon
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Gere uma string aleatória forte:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="gere-uma-string-aleatoria-longa-aqui"
JWT_EXPIRES_IN="7d"

PORT=3000
NODE_ENV=production

# URL do frontend no Vercel (sem barra no final)
FRONTEND_URL="https://seu-projeto.vercel.app"

# Chave do Gemini — mesma do dev
GEMINI_API_KEY="sua-chave-do-aistudio"
