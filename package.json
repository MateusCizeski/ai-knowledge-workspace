{
  "name": "ai-knowledge-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" --names \"BE,FE\" --prefix-colors \"blue,green\"",
    "dev:backend": "npm -w apps/backend run dev",
    "dev:frontend": "npm -w apps/frontend run dev",
    "build": "npm -w apps/backend run build && npm -w apps/frontend run build",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "npm -w apps/backend run test",
    "test:frontend": "npm -w apps/frontend run test",
    "test:coverage": "npm -w apps/backend run test:coverage && npm -w apps/frontend run test:coverage",
    "docker:up": "docker-compose up -d postgres",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:migrate": "npm -w apps/backend run db:migrate",
    "db:generate": "npm -w apps/backend run db:generate",
    "db:studio": "npm -w apps/backend run db:studio",
    "db:seed": "npm -w apps/backend run db:seed",
    "db:push": "npm -w apps/backend run db:push"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
